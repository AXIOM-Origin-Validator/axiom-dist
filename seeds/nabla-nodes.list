# AXIOM Nabla node seed list — the canonical, hand-edited default.
#
# Same line format as validators.list:  "name", "ed25519 pubkey (64 hex)", "carriers"
#   pubkey   — the Nabla node's Ed25519 key; empty if not pinned.
#   carriers — comma-separated <SCHEME>:<addr>. Nabla is reached over TCP;
#              the HTTP port is derived as tcp_port - 1074 (sdk/src/nabla.rs).
#
# Single source — edit directly, no generator. '#' lines are comments.
"alpha", "", "TCP:172.20.0.42:7300"
"beta", "", "TCP:172.20.0.42:7301"
"gamma", "", "TCP:172.20.0.42:7302"
"delta", "", "TCP:172.20.0.42:7303"
"epsilon", "", "TCP:172.20.0.42:7304"
"zeta", "", "TCP:172.20.0.42:7305"
"eta", "", "TCP:172.20.0.42:7306"
"theta", "", "TCP:172.20.0.42:7307"
"iota", "", "TCP:172.20.0.42:7308"
"kappa", "", "TCP:172.20.0.42:7309"
